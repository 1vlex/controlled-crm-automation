# Copy to .env for local runs. Keep .env out of reports and commits.

# LLM providers
GROQ_API_KEY=
GROQ_API_KEYS=
OPENAI_API_KEY=
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_MODEL=gpt-4o-mini

# Odoo XML-RPC
ODOO_URL=http://localhost:8069
ODOO_DB=Crm_hse
ODOO_EMAIL=
ODOO_PASSWORD=

# Docker / Odoo bootstrap
POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=
ODOO_MASTER_PASSWORD=
ODOO_DB_HOST=db
ODOO_DB_PORT=5432

# RPA runtime behavior
RPA_INPUT_TIMEZONE=Europe/Moscow
RPA_LOG_DIR=logs
RPA_ARTIFACT_DIR=artifacts
RPA_STRICT=false
RPA_SELF_HEALING_ENABLED=true
RPA_SELF_HEAL_MODE=auto
RPA_SELF_HEAL_MIN_SCORE=0.85
RPA_AUTO_CREATE_MISSING_DEALS=false
RPA_AUTO_CREATE_ACTIVITY_TYPE=true
RPA_FALLBACK_TO_CURRENT_USER=false
RPA_FALLBACK_TO_FIRST_STAGE=false
RPA_ALERT_ON_STEP_FAILURE=true
RPA_MAX_ALIAS_FALLBACK_DEALS=5
RPA_DEAL_TITLE_SEARCH_MIN_SCORE=0.88
RPA_PHONE_HEAL_MIN_SCORE=0.96
RPA_DEAL_CREATE_REUSE_EXISTING=true
